# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Gmail 계정 (gog auth add로 인증 후 사용)
GMAIL_ACCOUNTS=("your_main@gmail.com" "your_work@gmail.com")

# 캘린더 ID (일정 자동 등록용)
# gog calendar calendars --account YOUR_EMAIL 으로 확인
CALENDAR_ID=your_calendar_id@group.calendar.google.com
